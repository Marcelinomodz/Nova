say "=== Teste Arrays ==="
let numeros = [1, 2, 3]
say "Array: " + numeros

// Usando push com parênteses
numeros.push(4)
numeros.push(5)
say "Após push: " + numeros

// Usando pop com parênteses
let ultimo = numeros.pop()
say "Pop: " + ultimo
say "Array final: " + numeros

// Usando length sem parênteses (propriedade)
say "Tamanho: " + numeros.length
