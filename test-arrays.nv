say "=== Teste de Arrays ==="

let numeros = [1, 2, 3, 4, 5]
let nomes = ["Ana", "João", "Pedro", "Maria"]

say "Números: " + numeros
say "Nomes: " + nomes

say ""
say "=== Acesso por índice ==="
say "Primeiro número: " + numeros[0]
say "Último nome: " + nomes[3]

say ""
say "=== Loop com arrays ==="
loop 5 {
    say numeros[loop_index]
}

say ""
say "✅ Teste concluído!"
