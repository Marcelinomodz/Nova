say "=== Nova v1.0 - Teste Completo ==="
say ""

say "=== 1. ARRAYS ==="
let numeros = [1, 2, 3]
say "Array: " + numeros
numeros.push(4)
numeros.push(5)
say "Após push: " + numeros
let ultimo = numeros.pop()
say "Pop: " + ultimo
say "Array final: " + numeros
say "Tamanho: " + numeros.length

say ""
say "=== 2. STRINGS ==="
let nome = "Marcelino"
say "Nome: " + nome
say "Tamanho: " + nome.length
say "Maiúsculo: " + nome.upper
say "Minúsculo: " + nome.lower

say ""
say "=== 3. LOOP COM BREAK ==="
loop 10 {
    say "Loop: " + loop_index
    if loop_index == 5 {
        say "Break! Saindo..."
        break
    }
}

say ""
say "=== 4. LOOP COM CONTINUE ==="
loop 5 {
    if loop_index == 2 {
        say "Pulando 2..."
        continue
    }
    say "Valor: " + loop_index
}

say ""
say "=== 5. FOREACH ==="
let frutas = ["Maçã", "Banana", "Laranja", "Uva"]
foreach fruta in frutas {
    say "Fruta: " + fruta
}

say ""
say "✅ Teste v1.0 concluído!"
